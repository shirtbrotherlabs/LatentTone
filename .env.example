# Host path to the music library (mounted read-only at /music). Required.
MUSIC_LIBRARY=/path/to/your/music

# Host path for persistent data (covers, HLS segments, LanceDB vector index).
DATA_DIR=./data

# Host path for the MariaDB datadir (catalog / users / vectors status).
MARIADB_DATA=./data/mariadb

# MariaDB credentials — required, no defaults. Used to build DATABASE_DSN for
# browse/scan/embed (see docker-compose.yml).
MARIADB_PASSWORD=changeme-please
MARIADB_ROOT_PASSWORD=changeme-please-too

# Browse UI published port
BROWSE_PORT=8080

# Canonical public / self-referenced origin for reverse-proxy deployments.
# Used by the server and SPA for absolute URLs (MediaSession artwork, links).
# Local-only default. For reverse-proxy / mobile Wake Lock use your HTTPS origin.
PUBLIC_BASE_URL=http://localhost:8080
# Alias also accepted by the Go server: LATENTTONE_PUBLIC_URL

# Session cookie Secure flag. Omit to infer from PUBLIC_BASE_URL (https → true).
# Set false for plain-HTTP local access to :8080 while keeping an https public URL.
# SECURE_COOKIE=false
# LATENTTONE_SECURE_COOKIE=false

# Bootstrap admin (created on serve startup only if the username does not already exist).
# Leave empty to skip. Password is never reset on later restarts — change via Settings.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-please
